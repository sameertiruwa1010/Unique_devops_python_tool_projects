# cmd-ai environment variables
# Copy this to .env and fill in your values

# Required: Your OpenAI API key
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Optional: Use a different OpenAI model (default: gpt-4o-mini)
# Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# CMD_AI_MODEL=gpt-4o-mini

# Optional: Use local Ollama instead of OpenAI
# Set to "true" to use Ollama by default
# CMD_AI_USE_OLLAMA=false

# Optional: Ollama model name (default: mistral)
# CMD_AI_OLLAMA_MODEL=mistral
