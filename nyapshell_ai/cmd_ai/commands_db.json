{
  "find large files": "find / -size +100M -type f 2>/dev/null",
  "find large files in current folder": "find . -size +100M -type f 2>/dev/null",
  "check disk space": "df -h",
  "check disk usage by folder": "du -sh */ | sort -rh | head -20",
  "list running processes": "ps aux",
  "list running processes sorted by memory": "ps aux --sort=-%mem | head -20",
  "list running processes sorted by cpu": "ps aux --sort=-%cpu | head -20",
  "kill process by name": "pkill -f <process_name>",
  "kill process by port": "lsof -ti:<port> | xargs kill -9",
  "kill process by pid": "kill -9 <pid>",
  "show open ports": "ss -tulnp",
  "show open network connections": "netstat -tunapl",
  "check who is logged in": "who -a",
  "show logged in users": "w",
  "monitor cpu usage": "top -bn1 | grep 'Cpu'",
  "watch cpu and memory": "htop",
  "show memory usage": "free -h",
  "show system uptime": "uptime",
  "show system info": "uname -a",
  "show os version": "cat /etc/os-release",
  "list all files including hidden": "ls -la",
  "list files by size": "ls -lhS",
  "list files by date": "ls -lt",
  "find file by name": "find / -name '<filename>' 2>/dev/null",
  "find files modified in last 24 hours": "find . -mtime -1 -type f",
  "find files modified in last 7 days": "find . -mtime -7 -type f",
  "search text in files": "grep -r '<text>' .",
  "search text in file": "grep -n '<text>' <filename>",
  "compress folder to tar.gz": "tar -czf archive.tar.gz /path/to/folder",
  "extract tar.gz": "tar -xzf archive.tar.gz",
  "compress file with zip": "zip -r archive.zip /path/to/folder",
  "extract zip": "unzip archive.zip",
  "copy file": "cp source.txt destination.txt",
  "copy folder recursively": "cp -r /source/folder /destination/folder",
  "move file": "mv source.txt /destination/",
  "rename file": "mv oldname.txt newname.txt",
  "delete file": "rm filename.txt",
  "delete folder recursively": "rm -rf /path/to/folder",
  "delete empty directories": "find . -type d -empty -delete",
  "create directory": "mkdir -p /path/to/directory",
  "change file permissions": "chmod 755 filename",
  "change file owner": "chown user:group filename",
  "show file permissions": "ls -l filename",
  "create symlink": "ln -s /path/to/original /path/to/link",
  "show current directory": "pwd",
  "show environment variables": "printenv",
  "set environment variable": "export VAR_NAME=value",
  "add to path": "export PATH=$PATH:/new/path",
  "view file contents": "cat filename.txt",
  "view file with line numbers": "cat -n filename.txt",
  "view large file page by page": "less filename.txt",
  "view first 10 lines": "head filename.txt",
  "view last 10 lines": "tail filename.txt",
  "follow log file in real time": "tail -f /var/log/syslog",
  "watch logs in real time": "tail -f /var/log/syslog",
  "count lines in file": "wc -l filename.txt",
  "count words in file": "wc -w filename.txt",
  "sort file contents": "sort filename.txt",
  "remove duplicate lines": "sort -u filename.txt",
  "replace text in file": "sed -i 's/old_text/new_text/g' filename.txt",
  "show network interfaces": "ip addr show",
  "show ip address": "hostname -I",
  "ping a host": "ping -c 4 google.com",
  "trace route to host": "traceroute google.com",
  "download file from url": "wget https://example.com/file.zip",
  "download with curl": "curl -O https://example.com/file.zip",
  "check if port is open": "nc -zv hostname 80",
  "ssh to remote server": "ssh user@hostname",
  "copy file to remote server": "scp file.txt user@hostname:/remote/path/",
  "sync folders with rsync": "rsync -avz /source/ user@hostname:/destination/",
  "show firewall rules": "sudo iptables -L",
  "check service status": "systemctl status <service>",
  "start service": "systemctl start <service>",
  "stop service": "systemctl stop <service>",
  "restart service": "systemctl restart <service>",
  "enable service at boot": "systemctl enable <service>",
  "list all services": "systemctl list-units --type=service",
  "view system logs": "journalctl -xe",
  "view logs for service": "journalctl -u <service> -f",
  "show installed packages": "dpkg -l",
  "install package": "sudo apt install <package>",
  "remove package": "sudo apt remove <package>",
  "update packages": "sudo apt update && sudo apt upgrade",
  "search for package": "apt search <package>",
  "show package info": "apt show <package>",
  "add user": "sudo useradd -m <username>",
  "delete user": "sudo userdel -r <username>",
  "change password": "passwd <username>",
  "add user to group": "sudo usermod -aG <group> <username>",
  "show user groups": "groups <username>",
  "show all users": "cat /etc/passwd",
  "show all groups": "cat /etc/group",
  "run command as root": "sudo <command>",
  "switch to root": "sudo su -",
  "schedule cron job": "crontab -e",
  "list cron jobs": "crontab -l",
  "show disk partitions": "lsblk",
  "mount disk": "sudo mount /dev/sdb1 /mnt/disk",
  "unmount disk": "sudo umount /mnt/disk",
  "check filesystem": "sudo fsck /dev/sdb1",
  "show cpu info": "lscpu",
  "show hardware info": "lshw -short",
  "show pci devices": "lspci",
  "show usb devices": "lsusb",
  "show kernel version": "uname -r"
}
